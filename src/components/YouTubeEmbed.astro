---
interface Props {
  videoId: string
  title?: string
}

const { videoId, title = 'YouTube Video' } = Astro.props
const thumbnailUrl = `https://img.youtube.com/vi/${videoId}/maxresdefault.jpg`
---

<div class="youtube-embed-wrapper my-8">
  <div class="youtube-embed" data-video-id={videoId}>
    <!-- Placeholder: loads iframe on click for better performance -->
    <button
      class="youtube-placeholder"
      aria-label={`Video abspielen: ${title}`}
      style={`background-image: url(${thumbnailUrl})`}
    >
      <div class="youtube-play-btn">
        <svg viewBox="0 0 68 48" width="68" height="48">
          <path
            d="M66.52 7.74c-.78-2.93-2.49-5.41-5.42-6.19C55.79.13 34 0 34 0S12.21.13 6.9 1.55C3.97 2.33 2.27 4.81 1.48 7.74.06 13.05 0 24 0 24s.06 10.95 1.48 16.26c.78 2.93 2.49 5.41 5.42 6.19C12.21 47.87 34 48 34 48s21.79-.13 27.1-1.55c2.93-.78 4.64-3.26 5.42-6.19C67.94 34.95 68 24 68 24s-.06-10.95-1.48-16.26z"
            fill="#FF0000"
          />
          <path d="M45 24L27 14v20" fill="#fff" />
        </svg>
      </div>
    </button>
  </div>
</div>

<style>
  .youtube-placeholder {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    background-size: cover;
    background-position: center;
    border: none;
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: center;
    transition: filter 0.2s;
  }

  .youtube-placeholder:hover {
    filter: brightness(0.85);
  }

  .youtube-play-btn {
    background: rgba(0, 0, 0, 0.6);
    border-radius: 1rem;
    padding: 0.75rem 1rem;
    transition: background 0.2s;
  }

  .youtube-placeholder:hover .youtube-play-btn {
    background: rgba(255, 0, 0, 0.85);
  }
</style>

<script>
  document.querySelectorAll('.youtube-embed').forEach((container) => {
    const btn = container.querySelector('.youtube-placeholder')
    const videoId = container.getAttribute('data-video-id')
    if (!btn || !videoId) return

    btn.addEventListener('click', () => {
      const iframe = document.createElement('iframe')
      iframe.src = `https://www.youtube-nocookie.com/embed/${videoId}?autoplay=1&rel=0`
      iframe.allow = 'accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture'
      iframe.allowFullscreen = true
      iframe.title = 'YouTube Video'
      container.innerHTML = ''
      container.appendChild(iframe)
    })
  })
</script>
