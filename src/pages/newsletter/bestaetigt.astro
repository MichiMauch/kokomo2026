---
import BaseLayout from '../../layouts/BaseLayout.astro'
---

<BaseLayout title="Newsletter bestätigt" noIndex>
  <div class="py-24 text-center">
    <div class="mx-auto max-w-md">
      <div class="mb-6 text-5xl">🎉</div>
      <h1 class="text-2xl font-bold text-[var(--text)]">Willkommen an Bord!</h1>
      <p class="mt-4 text-[var(--text-secondary)] leading-relaxed">
        Deine Newsletter-Anmeldung wurde bestätigt. Du erhältst ab sofort Neuigkeiten
        aus unserem Tiny House direkt in dein Postfach.
      </p>
      <a
        href="/"
        class="mt-8 inline-block rounded-full bg-primary-500 px-6 py-3 text-sm font-medium text-white"
      >
        Zum Blog
      </a>
    </div>
  </div>
</BaseLayout>
