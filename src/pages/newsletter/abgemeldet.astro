---
import BaseLayout from '../../layouts/BaseLayout.astro'
---

<BaseLayout title="Newsletter abgemeldet" noIndex>
  <div class="py-24 text-center">
    <div class="mx-auto max-w-md">
      <h1 class="text-2xl font-bold text-[var(--text)]">Du wurdest abgemeldet</h1>
      <p class="mt-4 text-[var(--text-secondary)] leading-relaxed">
        Schade, dass du gehst! Du erhältst keine weiteren Newsletter-E-Mails von uns.
      </p>
      <a
        href="/"
        class="mt-8 inline-block rounded-full bg-primary-700px-6 py-3 text-sm font-medium text-white"
      >
        Zum Blog
      </a>
    </div>
  </div>
</BaseLayout>
