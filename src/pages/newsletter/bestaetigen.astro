---
export const prerender = false
import { getCollection } from 'astro:content'
import BaseLayout from '../../layouts/BaseLayout.astro'
import { confirmSubscriber, getSubscriberByToken, getLastSendWithBlocks } from '../../lib/newsletter'
import { sendMultiBlockNewsletterEmail } from '../../lib/notify'
import type { NewsletterBlock, PostRef } from '../../lib/newsletter-blocks'

const token = Astro.url.searchParams.get('token')
let success = false

if (token) {
  success = await confirmSubscriber(token)
}

if (success && token) {
  try {
    const [subscriber, lastSend] = await Promise.all([
      getSubscriberByToken(token),
      getLastSendWithBlocks(),
    ])
    if (subscriber && lastSend) {
      const blocks = JSON.parse(lastSend.blocks_json) as NewsletterBlock[]
      const slugs = new Set<string>()
      for (const block of blocks) {
        if (block.type === 'hero') slugs.add(block.slug)
        if (block.type === 'link-list') block.slugs.forEach((s: string) => slugs.add(s))
      }
      const allPosts = await getCollection('posts')
      const postsMap: Record<string, PostRef> = {}
      for (const slug of slugs) {
        const post = allPosts.find(p => p.id === slug || p.id.replace(/\.md$/, '') === slug)
        if (post) {
          postsMap[slug] = {
            slug: post.id,
            title: post.data.title,
            summary: post.data.summary ?? '',
            image: Array.isArray(post.data.images) ? post.data.images[0] ?? null : post.data.images ?? null,
            date: post.data.date.toISOString().split('T')[0],
          }
        }
      }
      const welcomeBlock: NewsletterBlock = {
        id: 'welcome',
        type: 'text',
        content: 'Willkommen bei KOKOMO House! 🎉\n\nSchön, dass du dabei bist. Damit du gleich weisst, was dich erwartet, bekommst du hier unseren letzten Newsletter. Ab jetzt bist du immer dabei, wenn wir Neues aus unserem Tiny-House-Abenteuer teilen.',
      }
      await sendMultiBlockNewsletterEmail({
        email: subscriber.email,
        unsubscribeToken: subscriber.token,
        subject: 'Willkommen bei KOKOMO House 🏠',
        blocks: [welcomeBlock, ...blocks],
        postsMap,
      })
    }
  } catch (err) {
    console.error('[bestaetigen] Willkommens-Newsletter fehlgeschlagen:', err)
  }
}

if (success) {
  return Astro.redirect('/newsletter/bestaetigt')
}
---

<BaseLayout title="Ungültiger Link" noIndex>
  <div class="py-24 text-center">
    <h1 class="text-2xl font-bold text-[var(--text)]">Ungültiger oder abgelaufener Link</h1>
    <p class="mt-4 text-[var(--text-secondary)]">
      Dieser Bestätigungslink ist nicht mehr gültig. Bitte melde dich erneut an.
    </p>
    <a
      href="/"
      class="mt-6 inline-block rounded-full bg-primary-500 px-6 py-3 text-sm font-medium text-white"
    >
      Zur Startseite
    </a>
  </div>
</BaseLayout>
