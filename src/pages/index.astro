---
export const prerender = true
import { getCollection } from 'astro:content'
import BaseLayout from '../layouts/BaseLayout.astro'
import PostCard from '../components/PostCard.astro'
import Pin from '../components/Pin.astro'
import { sortPostsByDate } from '../lib/utils'
import { siteConfig } from '../lib/site-config'
import { getGlossaryTerms, slugifyTerm } from '../lib/glossary'

const allPosts = await getCollection('posts', ({ data }) => !data.draft)

const allTerms = getGlossaryTerms()
const now = new Date()
const dayOfYear = Math.floor((now.getTime() - new Date(now.getFullYear(), 0, 0).getTime()) / 86400000)
const todayTerm = allTerms[dayOfYear % allTerms.length]
const sortedPosts = sortPostsByDate(allPosts)
const moveInDate = new Date(2022, 8, 17)
const daysSinceMoveIn = Math.floor((Date.now() - moveInDate.getTime()) / 86400000)
---

<BaseLayout>
  <!-- JSON-LD: WebSite + Organization -->
  <script type="application/ld+json" set:html={JSON.stringify({
    '@context': 'https://schema.org',
    '@graph': [
      {
        '@type': 'WebSite',
        '@id': `${siteConfig.siteUrl}/#website`,
        url: siteConfig.siteUrl,
        name: siteConfig.title,
        description: siteConfig.description,
        inLanguage: siteConfig.language,
        publisher: { '@id': `${siteConfig.siteUrl}/#organization` },
      },
      {
        '@type': 'Organization',
        '@id': `${siteConfig.siteUrl}/#organization`,
        name: siteConfig.title,
        url: siteConfig.siteUrl,
        logo: {
          '@type': 'ImageObject',
          url: `${siteConfig.siteUrl}${siteConfig.siteLogo}`,
        },
        sameAs: [
          siteConfig.instagram,
          siteConfig.facebook,
          siteConfig.linkedin,
        ].filter(Boolean),
      },
      {
        '@type': 'CollectionPage',
        '@id': `${siteConfig.siteUrl}/`,
        url: `${siteConfig.siteUrl}/`,
        name: siteConfig.title,
        description: siteConfig.description,
        isPartOf: { '@id': `${siteConfig.siteUrl}/#website` },
      },
    ],
  })} />

  <!-- Hero Section -->
  <section class="py-10 md:py-16 text-center">
    <div class="mx-auto max-w-3xl">
      <h1 class="mb-3 text-4xl font-bold tracking-tight font-[family-name:var(--font-sans)] md:text-5xl lg:text-6xl">
        <span class="text-gradient title-wave" aria-label={siteConfig.title}>
          {siteConfig.title.split('').map((char, i) => (
            <span
              class="title-wave-char"
              style={`--wave-delay: ${i * 0.06}s`}
            >{char === ' ' ? '\u00A0' : char}</span>
          ))}
        </span>
      </h1>
      <div class="mb-5 flex min-h-[1.25rem] items-center justify-center gap-3 text-sm text-[var(--text-secondary)]">
        <span id="days-counter">seit {daysSinceMoveIn} Tagen</span>
        <span id="battery-status" class="flex items-center gap-1"></span>
      </div>
      <p class="min-h-[5rem] text-lg leading-relaxed text-[var(--text-secondary)] sm:min-h-[4rem] md:min-h-[4.5rem] md:text-xl">
        <strong class="text-[var(--text)]"><span id="typewriter" class="typewriter">Brauchen wir wirklich 100 Quadratmeter, um zufrieden und glücklich zu sein?</span></strong>
        <br /><span id="typewriter-sub" class="typewriter">Seit September 2022 leben wir in unserem Tiny House KOKOMO. Erfahre auf unserem Blog alles über das Leben in einem Tiny House auf 36m².</span>
      </p>
    </div>
  </section>

  <!-- Fotowand: Polaroid-Karten -->
  <section class="mb-16">
    <div class="fotowand grid gap-10 px-2 sm:grid-cols-2 sm:gap-8 lg:grid-cols-3 lg:gap-10">
      {sortedPosts.map((post, i) => (
        <>
          {i === 3 && (
            <div class="col-span-full flex justify-center py-2">
              <a href={`/glossar/#${slugifyTerm(todayTerm.term)}`}
                 class="polaroid begriff-des-tages group block w-full max-w-sm sm:max-w-md p-4 pb-5"
                 style="--rotation: -2.5deg;">
                <Pin color="red" />
                <div class="mb-1 text-xs font-semibold uppercase tracking-wider text-[#0092d1]">
                  Begriff des Tages
                </div>
                <div class="text-lg font-bold">{todayTerm.term}</div>
                <div class="mt-1 text-sm leading-relaxed text-[var(--text-secondary)] line-clamp-2">
                  {todayTerm.definition}
                </div>
                <div class="mt-2 mb-2 text-xs font-medium text-[#0092d1] transition-colors group-hover:text-primary-600">
                  Im Glossar ansehen →
                </div>
              </a>
            </div>
          )}
          <div data-post-index={i} class={i >= 9 ? 'hidden' : ''}>
            <PostCard
              title={post.data.title}
              slug={post.id}
              date={post.data.date}
              summary={post.data.summary}
              tags={post.data.tags}
              images={post.data.images}
              pinColor={(['blue', 'green', 'beige'] as const)[i % 3]}
              eager={i < 3}
            />
          </div>
        </>
      ))}
    </div>
  </section>

  <!-- Load More -->
  <section class="mb-20 text-center">
    <div id="load-more-wrapper">
      <button
        id="load-more"
        class="group inline-flex items-center gap-2 rounded-full bg-primary-700px-8 py-3 font-medium text-white transition-all hover:bg-primary-800 hover:shadow-lg hover:shadow-primary-500/20 cursor-pointer"
      >
        Weitere Beiträge laden
        <svg class="h-4 w-4 transition-transform group-hover:translate-x-1" fill="none" viewBox="0 0 24 24" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3" />
        </svg>
      </button>
    </div>
  </section>
</BaseLayout>

<script>
  const BATCH = 9
  let visible = 9
  const btn = document.getElementById('load-more')
  const wrapper = document.getElementById('load-more-wrapper')
  const posts = document.querySelectorAll('[data-post-index]')

  if (posts.length <= BATCH) wrapper?.classList.add('hidden')

  btn?.addEventListener('click', () => {
    const next = Math.min(visible + BATCH, posts.length)
    for (let i = visible; i < next; i++) {
      posts[i].classList.remove('hidden')
    }
    visible = next
    if (visible >= posts.length) wrapper?.classList.add('hidden')
  })

  // Typewriter
  const line1 = 'Brauchen wir wirklich 100 Quadratmeter, um zufrieden und glücklich zu sein?'
  const line2 = 'Seit September 2022 leben wir in unserem Tiny House KOKOMO. Erfahre auf unserem Blog alles über das Leben in einem Tiny House auf 36m².'
  const el1 = document.getElementById('typewriter')
  const el2 = document.getElementById('typewriter-sub')

  function typeText(el: HTMLElement, text: string, speed: number): Promise<void> {
    return new Promise((resolve) => {
      if (window.matchMedia('(prefers-reduced-motion: reduce)').matches) {
        el.textContent = text
        el.classList.add('done')
        resolve()
        return
      }
      el.classList.add('typing')
      let i = 0
      function tick() {
        el.textContent = text.slice(0, i + 1)
        i++
        if (i < text.length) {
          setTimeout(tick, speed)
        } else {
          el.classList.remove('typing')
          el.classList.add('done')
          resolve()
        }
      }
      tick()
    })
  }

  // Typewriter nur bei Nicht-Reduced-Motion starten
  if (!window.matchMedia('(prefers-reduced-motion: reduce)').matches) {
    if (el1) el1.textContent = ''
    if (el2) el2.textContent = ''
    ;(async () => {
      if (el1) await typeText(el1, line1, 35)
      if (el2) await typeText(el2, line2, 20)
    })()
  }
</script>
