---
export const prerender = false

// Redirect to newsletter-app which handles unsubscribe logic
const token = Astro.url.searchParams.get('token')
const newsletterApp = import.meta.env.PUBLIC_NEWSLETTER_APP_URL || 'https://newsletter.kokomo.house'
return Astro.redirect(`${newsletterApp}/unsubscribe?token=${token || ''}`)
---
