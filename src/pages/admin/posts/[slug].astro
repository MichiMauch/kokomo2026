---
export const prerender = false
import BaseLayout from '../../../layouts/BaseLayout.astro'
import AdminPostDetail from '../../../components/islands/AdminPostDetail'

const { slug } = Astro.params
---

<BaseLayout title="Post bearbeiten" noIndex>
  <div class="py-12">
    <div class="mb-8 flex items-center gap-4">
      <h1 class="text-2xl font-bold text-[var(--text)]">Post bearbeiten</h1>
      <a
        href="/admin/posts"
        class="rounded-full border border-slate-300 px-4 py-1.5 text-xs font-medium text-[var(--text-secondary)] transition-colors hover:bg-slate-100 dark:border-slate-600 dark:hover:bg-slate-800"
      >
        Posts
      </a>
      <a
        href="/admin/content"
        class="rounded-full border border-slate-300 px-4 py-1.5 text-xs font-medium text-[var(--text-secondary)] transition-colors hover:bg-slate-100 dark:border-slate-600 dark:hover:bg-slate-800"
      >
        Blog-Content
      </a>
      <a
        href="/admin/comments"
        class="rounded-full border border-slate-300 px-4 py-1.5 text-xs font-medium text-[var(--text-secondary)] transition-colors hover:bg-slate-100 dark:border-slate-600 dark:hover:bg-slate-800"
      >
        Kommentare
      </a>
      <a
        href="/admin/newsletter"
        class="rounded-full border border-slate-300 px-4 py-1.5 text-xs font-medium text-[var(--text-secondary)] transition-colors hover:bg-slate-100 dark:border-slate-600 dark:hover:bg-slate-800"
      >
        Newsletter
      </a>
      <a
        href="/admin/glossar"
        class="rounded-full border border-slate-300 px-4 py-1.5 text-xs font-medium text-[var(--text-secondary)] transition-colors hover:bg-slate-100 dark:border-slate-600 dark:hover:bg-slate-800"
      >
        Glossar
      </a>
    </div>
    <AdminPostDetail client:load slug={slug!} />
  </div>
</BaseLayout>
