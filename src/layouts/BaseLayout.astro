---
import '../styles/global.css'
import '@fontsource/poppins/400.css'
import '@fontsource/poppins/500.css'
import '@fontsource/poppins/700.css'
import '@fontsource/roboto/400.css'
import '@fontsource/roboto/500.css'
import '@fontsource/roboto/700.css'
import Header from '../components/Header.astro'
import Footer from '../components/Footer.astro'
import AnimatedBackground from '../components/islands/AnimatedBackground'
import { siteConfig } from '../lib/site-config'

interface Props {
  title?: string
  description?: string
  image?: string
  article?: boolean
  noIndex?: boolean
  publishedTime?: Date
  modifiedTime?: Date
  tags?: string[]
  author?: string
}

const {
  title,
  description = siteConfig.description,
  image = siteConfig.socialBanner,
  article = false,
  noIndex = false,
  publishedTime,
  modifiedTime,
  tags = [],
  author = siteConfig.author,
} = Astro.props

const pageTitle = title ? `${title} | ${siteConfig.title}` : siteConfig.title
const canonicalUrl = new URL(Astro.url.pathname, siteConfig.siteUrl).href

// OG Image: always use dynamic /api/og endpoint for consistent branded previews
// If a post image is provided, pass it along so it appears in the OG card
const postImage = image?.startsWith('http') ? image : image && image !== siteConfig.socialBanner ? new URL(image, siteConfig.siteUrl).href : ''
const ogImage = `${siteConfig.siteUrl}/api/og?title=${encodeURIComponent(title || siteConfig.title)}&description=${encodeURIComponent(description)}${postImage ? `&image=${encodeURIComponent(postImage)}` : ''}`

// Auto-generate BreadcrumbList for non-article pages (articles have their own in PostLayout)
const pathSegments = Astro.url.pathname.replace(/\/$/, '').split('/').filter(Boolean)
const breadcrumbNames: Record<string, string> = {
  'tiny-house': 'Blog',
  'ueber-uns': 'Über uns',
  'newsletter': 'Newsletter',
  'tags': 'Tags',
  'page': 'Seite',
}
const breadcrumbItems = [
  { name: 'Home', url: siteConfig.siteUrl },
  ...pathSegments.map((seg, i) => ({
    name: breadcrumbNames[seg] || decodeURIComponent(seg).replace(/-/g, ' '),
    url: `${siteConfig.siteUrl}/${pathSegments.slice(0, i + 1).join('/')}/`,
  })),
]
const breadcrumbLd = !article && pathSegments.length > 0 ? {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: breadcrumbItems.map((item, i) => ({
    '@type': 'ListItem',
    position: i + 1,
    name: item.name,
    item: item.url,
  })),
} : null
---

<!doctype html>
<html lang={siteConfig.language} class="scroll-smooth">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link rel="icon" type="image/svg+xml" href="/static/images/kokomo-bildmarke.svg" />

    <!-- SEO -->
    <title>{pageTitle}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonicalUrl} />
    {noIndex && <meta name="robots" content="noindex,nofollow" />}

    <!-- Open Graph -->
    <meta property="og:title" content={title || siteConfig.title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:site_name" content={siteConfig.title} />
    <meta property="og:locale" content={siteConfig.locale} />
    <meta property="og:type" content={article ? 'article' : 'website'} />
    <meta property="og:image" content={ogImage} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:image:type" content="image/png" />
    <meta property="og:image:alt" content={title || siteConfig.title} />
    {article && publishedTime && (
      <meta property="article:published_time" content={publishedTime.toISOString()} />
    )}
    {article && modifiedTime && (
      <meta property="article:modified_time" content={modifiedTime.toISOString()} />
    )}
    {article && author && (
      <meta property="article:author" content={author} />
    )}
    {article && tags.map((tag) => (
      <meta property="article:tag" content={tag} />
    ))}
    {article && (
      <meta property="article:section" content="Tiny House" />
    )}

    <!-- Twitter / X -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title || siteConfig.title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImage} />
    <meta name="twitter:image:alt" content={title || siteConfig.title} />
    <meta name="twitter:site" content="@kokomohouse" />

    <!-- Breadcrumb JSON-LD -->
    {breadcrumbLd && <script type="application/ld+json" set:html={JSON.stringify(breadcrumbLd)} />}

    <!-- RSS -->
    <link
      rel="alternate"
      type="application/rss+xml"
      title={siteConfig.title}
      href="/rss.xml"
    />

    <!-- Dark Mode (inline to prevent flash) -->
    <script is:inline>
      ;(function () {
        const theme = localStorage.getItem('theme')
        if (
          theme === 'dark' ||
          (!theme && window.matchMedia('(prefers-color-scheme: dark)').matches)
        ) {
          document.documentElement.classList.add('dark')
        }
      })()
    </script>

    <!-- Matomo Analytics (skip on localhost) -->
    <script is:inline>
      if (!['localhost','127.0.0.1'].includes(window.location.hostname)) {
        var _paq = window._paq = window._paq || [];
        _paq.push(['trackPageView']);
        _paq.push(['enableLinkTracking']);
        (function() {
          var u="//matomo.kokomo.house/";
          _paq.push(['setTrackerUrl', u+'matomo.php']);
          _paq.push(['setSiteId', '1']);
          var d=document, g=d.createElement('script'), s=d.getElementsByTagName('script')[0];
          g.async=true; g.src=u+'matomo.js'; s.parentNode.insertBefore(g,s);
        })();
      }
    </script>
  </head>
  <body class="min-h-screen text-[var(--text)] antialiased">
    <AnimatedBackground client:visible />
    <Header />
    <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
      <main class="mb-auto">
        <slot />
      </main>
      <div class="page-curtain" id="page-curtain"></div>
      <Footer />
    </div>
    <script is:inline>
      (function () {
        if (window.matchMedia('(prefers-reduced-motion: reduce)').matches) return;
        var curtain = document.getElementById('page-curtain');
        if (!curtain) return;

        if (sessionStorage.getItem('navigating')) {
          sessionStorage.removeItem('navigating');
          curtain.style.transform = 'translateX(0)';
          curtain.offsetHeight;
          curtain.classList.add('wipe-out');
        }

        document.addEventListener('click', function (e) {
          var link = e.target.closest('a');
          if (!link) return;
          var href = link.getAttribute('href');
          if (!href) return;
          if (link.target === '_blank') return;
          if (href.startsWith('#') || href.startsWith('mailto:') || href.startsWith('tel:')) return;
          if (href.startsWith('http') && !href.startsWith(window.location.origin)) return;

          e.preventDefault();
          sessionStorage.setItem('navigating', '1');
          curtain.classList.remove('wipe-out');
          curtain.style.transform = '';
          curtain.offsetHeight;
          curtain.classList.add('wipe-in');
          curtain.addEventListener('animationend', function onEnd() {
            curtain.removeEventListener('animationend', onEnd);
            window.location.href = href;
          });
        });
      })();
    </script>
  </body>
</html>
