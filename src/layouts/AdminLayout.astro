---
/**
 * Dediziertes Admin-Layout: Sidebar links, schmale Topbar, neutraler
 * Tool-Look (.admin-shell Tokens in global.css). Kein Public-Chrome
 * (Header/Footer/AnimatedBackground/NewsletterPopup/Matomo/Curtain).
 */
import '../styles/global.css'
import '@fontsource/poppins/latin-400.css'
import '@fontsource/poppins/latin-700.css'
import '@fontsource/roboto/latin-400.css'
import '@fontsource/roboto/latin-500.css'
import '@fontsource/roboto/latin-700.css'
import AdminSidebar from '../components/AdminSidebar.astro'
import ThemeScript from '../components/ThemeScript.astro'
import ThemeToggle from '../components/ThemeToggle.astro'

interface Props {
  title: string
}

const { title } = Astro.props
---

<!doctype html>
<html lang="de" class="scroll-smooth">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link rel="icon" type="image/svg+xml" href="/static/images/kokomo-bildmarke.svg" />
    <title>{title} · KOKOMO Admin</title>
    <meta name="robots" content="noindex,nofollow" />
    <ThemeScript />
  </head>
  <body class="admin-shell min-h-screen bg-[var(--admin-bg)] text-[var(--text)] antialiased">
    <!-- Mobile-Drawer-State (peer für Sidebar + Backdrop) -->
    <input type="checkbox" id="admin-nav-toggle" class="peer sr-only" />

    <AdminSidebar />

    <div class="lg:pl-60">
      <header
        class="sticky top-0 z-30 flex h-14 items-center gap-3 border-b border-[var(--admin-border)] bg-[var(--admin-surface)] px-4 lg:px-8"
      >
        <label
          for="admin-nav-toggle"
          class="cursor-pointer rounded-lg p-2 text-[var(--text-secondary)] hover:bg-[var(--admin-surface-2)] lg:hidden"
          aria-label="Navigation öffnen"
        >
          <svg class="h-5 w-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round">
            <line x1="3" y1="6" x2="21" y2="6"></line>
            <line x1="3" y1="12" x2="21" y2="12"></line>
            <line x1="3" y1="18" x2="21" y2="18"></line>
          </svg>
        </label>
        <h1 class="font-sans text-base font-semibold text-[var(--text)]">{title}</h1>
        <div class="ml-auto flex items-center gap-2">
          <slot name="actions" />
          <ThemeToggle />
        </div>
      </header>
      <main class="p-4 lg:p-8">
        <slot />
      </main>
    </div>
  </body>
</html>
