---
import { formatDate, getPostImage, getReadingTime, truncate } from '../lib/utils'
import { siteConfig } from '../lib/site-config'
import GalleryLightbox from '../components/islands/GalleryLightbox'
import CommentSection from '../components/islands/CommentSection'
import YouTubeEmbed from '../components/YouTubeEmbed.astro'
import { getGlossaryTerms, slugifyTerm } from '../lib/glossary'
import type { CollectionEntry } from 'astro:content'

interface Props {
  post: CollectionEntry<'posts'>
  headings: Array<{ depth: number; slug: string; text: string }>
  prevPost?: CollectionEntry<'posts'> | null
  nextPost?: CollectionEntry<'posts'> | null
}

const { post, headings, prevPost, nextPost } = Astro.props
const { title, date, tags, images, summary, authors, youtube, lastmod } = post.data
const imageUrl = getPostImage(images)
const prevImage = prevPost ? getPostImage(prevPost.data.images) : null
const nextImage = nextPost ? getPostImage(nextPost.data.images) : null
const readingTime = getReadingTime(post.body || '')
const postUrl = `${siteConfig.siteUrl}/tiny-house/${post.slug}/`

// JSON-LD: BlogPosting
const jsonLd = {
  '@context': 'https://schema.org',
  '@type': 'BlogPosting',
  headline: title,
  description: summary,
  image: imageUrl,
  url: postUrl,
  mainEntityOfPage: { '@type': 'WebPage', '@id': postUrl },
  datePublished: date.toISOString(),
  ...(lastmod && { dateModified: lastmod.toISOString() }),
  author: {
    '@type': 'Person',
    name: siteConfig.author,
    url: siteConfig.siteUrl,
  },
  publisher: {
    '@type': 'Organization',
    name: siteConfig.title,
    logo: {
      '@type': 'ImageObject',
      url: `${siteConfig.siteUrl}${siteConfig.siteLogo}`,
    },
  },
  inLanguage: siteConfig.language,
  keywords: tags.join(', '),
  speakable: {
    '@type': 'SpeakableSpecification',
    cssSelector: ['.prose h1', '.prose h2', '.prose h3', '.prose p:first-of-type'],
  },
}

// JSON-LD: BreadcrumbList
const breadcrumbLd = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    {
      '@type': 'ListItem',
      position: 1,
      name: 'Home',
      item: siteConfig.siteUrl,
    },
    {
      '@type': 'ListItem',
      position: 2,
      name: 'Blog',
      item: `${siteConfig.siteUrl}/tiny-house/`,
    },
    {
      '@type': 'ListItem',
      position: 3,
      name: title,
      item: postUrl,
    },
  ],
}

// JSON-LD: FAQPage (auto-detect Q&A patterns from headings)
const faqHeadings = headings.filter((h) =>
  h.text.match(/\?|warum|wie|was|wann|wo|wer|welch|kann|braucht|muss|soll|geht|lohnt|darf|gibt/i)
)
const faqItems = faqHeadings.map((h) => {
  // Extract answer: text between this heading and the next heading
  const body = post.body || ''
  const headingPattern = new RegExp(
    `#+\\s*${h.text.replace(/[.*+?^${}()|[\]\\]/g, '\\$&')}\\s*\\n([\\s\\S]*?)(?=\\n#{1,3}\\s|$)`
  )
  const match = body.match(headingPattern)
  const answer = match
    ? match[1].replace(/!\[.*?\]\(.*?\)/g, '').replace(/\[([^\]]+)\]\([^)]+\)/g, '$1').trim().slice(0, 500)
    : ''
  return answer ? { question: h.text, answer } : null
}).filter(Boolean)

const faqLd = faqItems.length >= 2 ? {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: faqItems.map((item) => ({
    '@type': 'Question',
    name: item!.question,
    acceptedAnswer: {
      '@type': 'Answer',
      text: item!.answer,
    },
  })),
} : null

// Glossary data for client-side tooltip injection
const glossaryData = getGlossaryTerms().map((t) => ({
  t: t.term,
  s: slugifyTerm(t.term),
  d: t.definition,
}))
---

<script type="application/ld+json" set:html={JSON.stringify(jsonLd)} />
<script type="application/ld+json" set:html={JSON.stringify(breadcrumbLd)} />
{faqLd && <script type="application/ld+json" set:html={JSON.stringify(faqLd)} />}
<script type="application/json" id="glossary-data" set:html={JSON.stringify(glossaryData)} />

<GalleryLightbox client:load />

<article class="my-8">
  <div class="flex flex-col gap-8 lg:flex-row">
    <!-- Sidebar (links auf Desktop, unten auf Mobile) -->
    <aside class="hidden w-56 shrink-0 lg:block">
      <div class="sticky top-24 space-y-4">
        <!-- Card 1: Inhaltsverzeichnis -->
        {headings.length > 0 && (
          <div class="glass-card rounded-2xl p-4">
            <nav>
              <h4 class="mb-2 text-xs font-semibold uppercase tracking-wider text-[var(--text-secondary)]">
                Inhalt
              </h4>
              <ul class="space-y-1.5 text-sm">
                {headings
                  .filter((h) => h.depth <= 3)
                  .map((heading) => (
                    <li class={heading.depth === 3 ? 'ml-3' : ''}>
                      <a
                        href={`#${heading.slug}`}
                        class="text-[var(--text-secondary)] transition-colors hover:text-primary-500"
                      >
                        {heading.text}
                      </a>
                    </li>
                  ))}
              </ul>
            </nav>
          </div>
        )}

        <!-- Card 2: Navigation (Übersicht + Prev/Next) -->
        <div class="glass-card rounded-2xl p-4 space-y-3">
          <a
            href="/"
            class="flex items-center gap-1.5 text-sm font-medium text-primary-500 transition-colors hover:text-primary-600"
          >
            <svg class="h-3.5 w-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7" />
            </svg>
            Zur Übersicht
          </a>

          {prevPost && (
            <a
              href={`/tiny-house/${prevPost.slug}/`}
              data-nav="prev"
              class="group block rounded-lg p-2 transition-colors hover:bg-white/50 dark:hover:bg-slate-800/50"
            >
              <span class="text-xs uppercase tracking-wider opacity-60">← Vorheriger</span>
              <p class="mt-0.5 line-clamp-2 text-sm font-medium">{prevPost.data.title}</p>
            </a>
          )}

          {nextPost && (
            <a
              href={`/tiny-house/${nextPost.slug}/`}
              data-nav="next"
              class="group block rounded-lg p-2 transition-colors hover:bg-white/50 dark:hover:bg-slate-800/50"
            >
              <span class="text-xs uppercase tracking-wider opacity-60">Nächster →</span>
              <p class="mt-0.5 line-clamp-2 text-sm font-medium">{nextPost.data.title}</p>
            </a>
          )}
        </div>
      </div>
    </aside>

    <!-- Hauptinhalt -->
    <div class="min-w-0 flex-1">
      <div class="glass-card rounded-2xl p-6 md:p-8">
        <!-- Header: Hero mit Overlay oder Fallback -->
        <header class="mb-8">
          {imageUrl ? (
            <!-- Hero mit Overlay -->
            <div class="relative mx-auto max-w-3xl overflow-hidden rounded-xl">
              <img
                src={imageUrl}
                alt={title}
                class="aspect-[16/9] w-full object-cover"
                loading="eager"
                decoding="async"
              />
              <!-- Gradient Overlay -->
              <div class="absolute inset-0 bg-gradient-to-t from-black/70 via-black/20 to-transparent" />
              <!-- Text Overlay -->
              <div class="absolute inset-x-0 bottom-0 p-5 md:p-7">
                <div class="mb-2 flex items-center gap-3 text-sm text-white/80">
                  <time class="font-medium" datetime={date.toISOString()}>
                    {formatDate(date)}
                  </time>
                  <span>·</span>
                  <span>{readingTime}</span>
                </div>
                <h1 class="text-2xl font-bold tracking-tight text-white md:text-3xl lg:text-4xl drop-shadow-[0_2px_4px_rgba(0,0,0,0.3)]">
                  {title}
                </h1>
              </div>
            </div>
          ) : (
            <!-- Fallback ohne Bild -->
            <div class="mx-auto max-w-3xl">
              <div class="mb-4 flex items-center gap-3 text-sm">
                <time class="font-medium text-primary-500" datetime={date.toISOString()}>
                  {formatDate(date)}
                </time>
                <span class="text-[var(--text-secondary)]">·</span>
                <span class="text-[var(--text-secondary)]">{readingTime}</span>
              </div>
              <h1 class="text-3xl font-bold tracking-tight font-[family-name:var(--font-sans)] md:text-4xl lg:text-[2.75rem] lg:leading-tight">
                {title}
              </h1>
            </div>
          )}
        </header>

        <!-- Summary Snippet (for AEO/GEO) -->
        {summary && (
          <div class="mx-auto mb-6 max-w-3xl">
            <details class="glass-card rounded-xl border border-primary-500/20 p-4" open>
              <summary class="cursor-pointer text-sm font-semibold uppercase tracking-wider text-primary-500">
                Zusammenfassung
              </summary>
              <p class="mt-2 text-[var(--text-secondary)] leading-relaxed" data-speakable="true">
                {summary}
              </p>
            </details>
          </div>
        )}

        <!-- Prose Content -->
        <div class="mx-auto max-w-3xl">
          <div class="prose prose-lg post-prose max-w-none dark:prose-invert">
            <slot />
          </div>
        </div>

        <!-- Tags (am Ende des Artikels) -->
        {tags.length > 0 && (
          <div class="mx-auto mt-8 max-w-3xl flex flex-wrap gap-2">
            {tags.map((tag) => (
              <a
                href={`/tags/${tag}/`}
                class="rounded-full bg-primary-500/10 px-3 py-1 text-xs font-medium text-primary-600 transition-colors hover:bg-primary-500/20 dark:text-primary-400"
              >
                {tag}
              </a>
            ))}
          </div>
        )}

        <!-- Kommentare -->
        <div class="mx-auto mt-12 max-w-3xl">
          <CommentSection client:visible slug={post.slug} />
        </div>

        <!-- Navigation (unterhalb des Contents) -->
        <div class="mt-12 border-t border-[var(--border)]/30 pt-8">
          <!-- Prev/Next -->
          <div class="flex flex-col gap-3 sm:flex-row sm:justify-between">
            {prevPost ? (
              <a
                href={`/tiny-house/${prevPost.slug}/`}
                class="glass-card group flex-1 overflow-hidden rounded-xl p-3 transition-all hover:shadow-lg hover:shadow-primary-500/10"
              >
                <div class="flex items-center gap-3">
                  {prevImage ? (
                    <img src={prevImage} alt="" class="h-14 w-14 shrink-0 rounded-lg object-cover" loading="lazy" />
                  ) : (
                    <div class="h-14 w-14 shrink-0 rounded-lg bg-gradient-to-br from-primary-400/30 to-secondary-400/30" />
                  )}
                  <div>
                    <span class="text-xs text-[var(--text-secondary)]">&larr; Vorheriger</span>
                    <p class="mt-1 line-clamp-2 text-sm font-medium text-[var(--text)] group-hover:text-primary-500">
                      {prevPost.data.title}
                    </p>
                  </div>
                </div>
              </a>
            ) : (
              <div class="flex-1" />
            )}
            {nextPost ? (
              <a
                href={`/tiny-house/${nextPost.slug}/`}
                class="glass-card group flex-1 overflow-hidden rounded-xl p-3 text-right transition-all hover:shadow-lg hover:shadow-primary-500/10"
              >
                <div class="flex items-center gap-3">
                  <div class="flex-1">
                    <span class="text-xs text-[var(--text-secondary)]">Nächster &rarr;</span>
                    <p class="mt-1 line-clamp-2 text-sm font-medium text-[var(--text)] group-hover:text-primary-500">
                      {nextPost.data.title}
                    </p>
                  </div>
                  {nextImage ? (
                    <img src={nextImage} alt="" class="h-14 w-14 shrink-0 rounded-lg object-cover" loading="lazy" />
                  ) : (
                    <div class="h-14 w-14 shrink-0 rounded-lg bg-gradient-to-br from-primary-400/30 to-secondary-400/30" />
                  )}
                </div>
              </a>
            ) : (
              <div class="flex-1" />
            )}
          </div>
        </div>
      </div>
    </div>
  </div>
</article>

<script>
document.addEventListener('DOMContentLoaded', () => {
  // Keyboard navigation: Arrow keys for prev/next post
  const prevLink = document.querySelector<HTMLAnchorElement>('[data-nav="prev"]');
  const nextLink = document.querySelector<HTMLAnchorElement>('[data-nav="next"]');
  document.addEventListener('keydown', (e) => {
    if (e.target instanceof HTMLInputElement || e.target instanceof HTMLTextAreaElement) return;
    if (e.key === 'ArrowLeft' && prevLink) prevLink.click();
    if (e.key === 'ArrowRight' && nextLink) nextLink.click();
  });

  const prose = document.querySelector('.post-prose');
  if (!prose) return;

  // 0) YouTube: {% youtube ID %} Tags durch Embed ersetzen
  prose.querySelectorAll('p').forEach((p) => {
    const match = p.textContent?.trim().match(/^\{%\s*youtube\s+([\w-]+)\s*%\}$/);
    if (!match) return;
    const videoId = match[1];
    const wrapper = document.createElement('div');
    wrapper.className = 'youtube-embed-wrapper my-8';
    wrapper.innerHTML = `
      <div class="youtube-embed" data-video-id="${videoId}" style="position:relative;padding-bottom:56.25%;height:0;overflow:hidden;border-radius:1rem">
        <button style="position:absolute;top:0;left:0;width:100%;height:100%;background-size:cover;background-position:center;background-color:#000;border:none;cursor:pointer;display:flex;align-items:center;justify-content:center" data-video-id-thumb="${videoId}" aria-label="Video abspielen">
          <div style="background:rgba(0,0,0,0.6);border-radius:1rem;padding:0.75rem 1rem;transition:background 0.2s">
            <svg viewBox="0 0 68 48" width="68" height="48">
              <path d="M66.52 7.74c-.78-2.93-2.49-5.41-5.42-6.19C55.79.13 34 0 34 0S12.21.13 6.9 1.55C3.97 2.33 2.27 4.81 1.48 7.74.06 13.05 0 24 0 24s.06 10.95 1.48 16.26c.78 2.93 2.49 5.41 5.42 6.19C12.21 47.87 34 48 34 48s21.79-.13 27.1-1.55c2.93-.78 4.64-3.26 5.42-6.19C67.94 34.95 68 24 68 24s-.06-10.95-1.48-16.26z" fill="#FF0000"/>
              <path d="M45 24L27 14v20" fill="#fff"/>
            </svg>
          </div>
        </button>
      </div>`;
    p.replaceWith(wrapper);

    // Load thumbnail
    const btn = wrapper.querySelector('button') as HTMLButtonElement;
    const sizes = ['maxresdefault', 'sddefault', 'hqdefault', 'mqdefault'];
    function tryThumb(i: number) {
      if (i >= sizes.length) return;
      const img = new Image();
      img.onload = () => {
        if (img.naturalWidth <= 120 && i < sizes.length - 1) tryThumb(i + 1);
        else btn.style.backgroundImage = `url(${img.src})`;
      };
      img.onerror = () => tryThumb(i + 1);
      img.src = `https://img.youtube.com/vi/${videoId}/${sizes[i]}.jpg`;
    }
    tryThumb(0);

    // Click to play
    btn.addEventListener('click', () => {
      const embed = wrapper.querySelector('.youtube-embed')!;
      const iframe = document.createElement('iframe');
      iframe.src = `https://www.youtube-nocookie.com/embed/${videoId}?autoplay=1&rel=0`;
      iframe.allow = 'accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture';
      iframe.allowFullscreen = true;
      iframe.title = 'YouTube Video';
      embed.innerHTML = '';
      embed.appendChild(iframe);
    });
  });

  // 1) Gallery: aufeinanderfolgende Einzelbilder zu Fotowand zusammenfassen
  const children = Array.from(prose.children);
  let i = 0;

  while (i < children.length) {
    if (isSoloImageParagraph(children[i])) {
      const run = [children[i]];
      let j = i + 1;
      while (j < children.length && isSoloImageParagraph(children[j])) {
        run.push(children[j]);
        j++;
      }

      if (run.length >= 2) {
        const gallery = document.createElement('div');
        gallery.className = 'image-gallery fotowand';

        for (const p of run) {
          const img = p.querySelector('img')!;
          const frame = document.createElement('div');
          frame.className = 'polaroid-frame';

          const tape = document.createElement('div');
          tape.className = 'tape';

          frame.appendChild(tape);
          frame.appendChild(img);
          gallery.appendChild(frame);
        }

        run[0].replaceWith(gallery);
        for (let k = 1; k < run.length; k++) {
          run[k].remove();
        }

        children.splice(0, children.length, ...Array.from(prose.children));
        i = children.indexOf(gallery) + 1;
        continue;
      }
    }
    i++;
  }

  // 2) Scroll-Reveal: nach Gallery-Aufbau alle Kinder observen
  if (window.matchMedia('(prefers-reduced-motion: reduce)').matches) {
    prose.querySelectorAll(':scope > *').forEach((el) => el.classList.add('is-visible'));
    return;
  }

  const observer = new IntersectionObserver(
    (entries) => {
      entries.forEach((entry) => {
        if (entry.isIntersecting) {
          entry.target.classList.add('is-visible');
          observer.unobserve(entry.target);
        }
      });
    },
    { rootMargin: '0px 0px -60px 0px', threshold: 0.15 }
  );

  prose.querySelectorAll(':scope > *').forEach((el) => observer.observe(el));

  // 3) Glossary Tooltips: link first occurrence of each term
  injectGlossaryTooltips(prose);

  // 4) Track glossary tooltip clicks via sendBeacon
  prose.addEventListener('click', (e) => {
    const link = (e.target as HTMLElement).closest('a.glossary-term');
    if (!link) return;
    const term = link.textContent?.trim().toLowerCase();
    if (term) {
      navigator.sendBeacon(
        '/api/glossary/track',
        new Blob([JSON.stringify({ term, type: 'click' })], { type: 'application/json' }),
      );
    }
  });

  // 5) Track glossary tooltip hovers (500ms debounce, once per term per pageview)
  const hoveredTerms = new Set<string>();
  let hoverTimer: ReturnType<typeof setTimeout> | null = null;
  let hoverTarget: Element | null = null;

  prose.addEventListener('mouseenter', (e) => {
    const link = (e.target as HTMLElement).closest('a.glossary-term');
    if (!link) return;
    const term = link.textContent?.trim().toLowerCase();
    if (!term || hoveredTerms.has(term)) return;

    hoverTarget = link;
    hoverTimer = setTimeout(() => {
      hoveredTerms.add(term);
      navigator.sendBeacon(
        '/api/glossary/track',
        new Blob([JSON.stringify({ term, type: 'hover' })], { type: 'application/json' }),
      );
      hoverTimer = null;
    }, 500);
  }, true);

  prose.addEventListener('mouseleave', (e) => {
    const link = (e.target as HTMLElement).closest('a.glossary-term');
    if (!link || link !== hoverTarget) return;
    if (hoverTimer) {
      clearTimeout(hoverTimer);
      hoverTimer = null;
    }
    hoverTarget = null;
  }, true);
});

function injectGlossaryTooltips(prose: Element) {
  const dataEl = document.getElementById('glossary-data');
  if (!dataEl) return;
  const terms: { t: string; s: string; d: string }[] = JSON.parse(dataEl.textContent || '[]');
  if (!terms.length) return;

  // Sort longer terms first to prevent partial matches
  terms.sort((a, b) => b.t.length - a.t.length);

  const matched = new Set<string>();
  const allowedParents = new Set(['P', 'LI', 'DD']);

  const walker = document.createTreeWalker(prose, NodeFilter.SHOW_TEXT, {
    acceptNode(node) {
      const parent = node.parentElement;
      if (!parent) return NodeFilter.FILTER_REJECT;
      // Skip headings, code, links, existing glossary terms
      const tag = parent.tagName;
      if (['A', 'CODE', 'PRE', 'H1', 'H2', 'H3', 'H4', 'H5', 'H6'].includes(tag)) {
        return NodeFilter.FILTER_REJECT;
      }
      // Check if any ancestor is an allowed container
      let el: HTMLElement | null = parent;
      while (el && el !== prose) {
        if (allowedParents.has(el.tagName)) return NodeFilter.FILTER_ACCEPT;
        el = el.parentElement;
      }
      return NodeFilter.FILTER_REJECT;
    },
  });

  const textNodes: Text[] = [];
  let node: Node | null;
  while ((node = walker.nextNode())) textNodes.push(node as Text);

  for (const textNode of textNodes) {
    for (const { t: term, s: slug, d: def } of terms) {
      if (matched.has(term)) continue;
      const text = textNode.textContent || '';
      const regex = new RegExp(`\\b${term.replace(/[.*+?^${}()|[\]\\]/g, '\\$&')}\\b`, 'i');
      const match = text.match(regex);
      if (!match || match.index === undefined) continue;

      matched.add(term);

      const before = text.slice(0, match.index);
      const matchedText = text.slice(match.index, match.index + match[0].length);
      const after = text.slice(match.index + match[0].length);

      const link = document.createElement('a');
      link.href = `/glossar/#${slug}`;
      link.className = 'glossary-term';
      link.setAttribute('data-glossary-definition', def);
      link.textContent = matchedText;

      const parent = textNode.parentNode!;
      if (before) parent.insertBefore(document.createTextNode(before), textNode);
      parent.insertBefore(link, textNode);
      if (after) parent.insertBefore(document.createTextNode(after), textNode);
      parent.removeChild(textNode);
      break; // Move to next text node since this one was split
    }
  }
}

function isSoloImageParagraph(el: Element): boolean {
  if (el.tagName !== 'P') return false;
  const imgs = el.querySelectorAll('img');
  const links = el.querySelectorAll('a');
  return imgs.length === 1 && links.length === 0 &&
    el.textContent!.trim() === '';
}
</script>
